# NUDGE Harness — 환경변수 설정
# 이 파일을 .env로 복사한 뒤 API 키를 채워넣으세요.
# cp .env.example .env

# ═══ Provider 선택 ═══
RALPHTHON_PROVIDER=gemini

# ═══ API Keys (사용할 프로바이더만 설정) ═══
GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OLLAMA_BASE_URL=http://localhost:11434

# ═══ 모델 설정 ═══
# RALPHTHON_MODEL_CHEAP=gemini-2.0-flash-lite
# RALPHTHON_MODEL_EXPENSIVE=gemini-2.0-flash

# ═══ 실행 설정 ═══
# RALPHTHON_MODE=DEV          # DEV=10명, TEST=50명, DEMO=200명
# RALPHTHON_MAX_CONCURRENT=20
# RALPHTHON_CONVERSATION_TURNS=3
# RALPHTHON_STRATEGIES_PER_RUN=3
