{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy.schema.json",
  "title": "Strategy",
  "description": "H(Hypothesize) 단계에서 생성하는 설득 전략 1개",
  "type": "object",
  "required": [
    "strategy_id",
    "hypothesis",
    "approach",
    "opening_style",
    "objection_handling",
    "tone"
  ],
  "additionalProperties": false,
  "properties": {
    "strategy_id": {
      "type": "string",
      "pattern": "^strategy-",
      "description": "전략 고유 ID (strategy- 접두사)"
    },
    "hypothesis": {
      "type": "string",
      "description": "이 전략이 왜 효과적인지 가설"
    },
    "approach": {
      "type": "string",
      "description": "구체적인 설득 접근법"
    },
    "opening_style": {
      "type": "string",
      "description": "첫 인사/오프닝 방식"
    },
    "objection_handling": {
      "type": "string",
      "description": "예상 반론 대응법"
    },
    "tone": {
      "type": "string",
      "description": "전체 대화 톤"
    }
  }
}