# Ralphthon Harness — 환경변수
# 이 파일을 .env로 복사하고 GEMINI_API_KEY를 넣어라.
# cp .env.example .env

# ── LLM 프로바이더 ──────────────────────────────────
RALPHTHON_PROVIDER=gemini

# ── API Key (필수) ──────────────────────────────────
GEMINI_API_KEY=여기에_키_입력

# ── 모델 설정 ───────────────────────────────────────
# 싼 모델: 대화 생성용 (Act 단계)
RALPHTHON_MODEL_CHEAP=gemini-2.0-flash-lite

# 비싼 모델: Judge/분석/전략생성용 (Hypothesize, Evaluate, Reason, Learn 단계)
RALPHTHON_MODEL_EXPENSIVE=gemini-2.5-pro

# ── 실험 모드 ───────────────────────────────────────
# DEV=10명, TEST=50명, DEMO=200명
RALPHTHON_MODE=DEV

# ── 시뮬레이션 파라미터 ─────────────────────────────
RALPHTHON_MAX_CONCURRENT=5
RALPHTHON_CONVERSATION_TURNS=3
RALPHTHON_STRATEGIES_PER_RUN=3

# ── (선택) 다른 프로바이더 ──────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
